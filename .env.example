# On-Prem RAG Assistant — Environment Configuration
# Copy this file to .env and edit the values for your setup.
#   macOS/Linux:  cp .env.example .env
#   Windows:      copy .env.example .env
#
# .env is listed in .gitignore — never commit it with real values.

# ── Ollama ─────────────────────────────────────────────────────
# URL where Ollama is listening.
# Default works for local installs. Change the host if Ollama runs
# on a separate machine or inside Docker (see docker-compose.yml).
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM used for answering questions.
# Can be overridden per-session via the model selector in the sidebar.
# Requires: ollama pull <model>
LLM_MODEL=qwen2.5:7b

# Embedding model — used to index documents and embed queries.
# Do NOT change this after building the knowledge base without
# deleting data/vector_db/ and rebuilding.
EMBED_MODEL=nomic-embed-text

# ── Paths ──────────────────────────────────────────────────────
# All paths are relative to the project root.

# Folder containing documents to index (PDF, DOCX, TXT, or Markdown).
DOCS_PATH=data/documents

# Persistent ChromaDB vector store location.
# Delete this folder to force a full rebuild.
CHROMA_PATH=data/vector_db

# Metadata sidecar file.
METADATA_PATH=data/metadata/metadata.json

# Query log file.
LOG_PATH=logs/questions.log

# ── Retrieval (optional overrides) ────────────────────────────
# Number of document sections retrieved per query.
# Increase for broader coverage; decrease for faster, tighter answers.
# TOP_K=3
# CHUNK_SIZE=600
# CHUNK_OVERLAP=80

# Maximum cosine distance accepted from vector search. Lower is stricter.
# Queries with no chunks below this threshold return a "not found" response.
# MAX_COSINE_DISTANCE=0.65

# Browser mode listens only on localhost by default. LAN mode currently has
# no authentication and should only be enabled on a trusted network.
# ALLOW_NETWORK_ACCESS=false
